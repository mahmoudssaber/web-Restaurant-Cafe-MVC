@model food_delivery.Models.Dish

@{
    ViewData["Title"] = "Edit";
}

<div class="row">
    <div class="col-md-2"></div>
    <div class="col-12 col-md-8">
        <h1 class="text-center">Edit Dish</h1>
        <h4>Dish</h4>
        <hr />
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="DishId" />
            <div class="form-group">
                <label asp-for="Name" class="control-label mt-3 fw-bold"></label>
                <input asp-for="Name" class="form-control mt-3" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label mt-3 fw-bold"></label>
                <input asp-for="Description" class="form-control mt-3" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label for="Image" class="control-label mt-3 fw-bold">Select image: </label>
                <input type="file" accept="image/*" name="Image" id="Image" class="form-control mt-3" />
                <span class="text-danger">@ViewBag?.error</span>
            </div>
            <div class="form-group">
                <label asp-for="TypeId" class="control-label mt-3 fw-bold">dish</label>
                <select asp-for="TypeId" class="form-control mt-3" asp-items="ViewBag.TypeId"></select>
                <span asp-validation-for="TypeId" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Keep" class="btn btn-primary me-5" />
                <a class="btn btn-info" asp-action="Index">Back</a>
            </div>
        </form>
    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
