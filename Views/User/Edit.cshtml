@using Microsoft.AspNetCore.Identity

@model food_delivery.Models.CustomUserDTO

@inject UserManager<CustomUser> UserManager

@{
    ViewData["Title"] = "Edit";
}

<div class="row">
    <div class="col-md-2"></div>
    <div class="col-12 col-md-8">
        <h1 class="text-center">Edit User</h1>
        <h4>User</h4>
        <hr />
        <form asp-controller="User" asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="FirstName" class="control-label mt-3 fw-bold"></label>
                <input type="text" asp-for="FirstName" class="form-control mt-3" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="LastName" class="control-label mt-3 fw-bold"></label>
                <input type="text" asp-for="LastName" class="form-control mt-3" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PhoneNumber" class="control-label mt-3 fw-bold"></label>
                <input type="tel" asp-for="PhoneNumber" class="form-control mt-3" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="control-label mt-3 fw-bold"></label>
                <input type="email" asp-for="Email" class="form-control mt-3" readonly />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Keep" class="btn btn-success me-5" />
                <a asp-controller="User" asp-action="Details" asp-route-id="@UserManager.GetUserId(User)" class="btn btn-info">Back</a>
            </div>
        </form>
    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
